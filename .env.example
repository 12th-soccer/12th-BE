# Full Docker image reference: repository/image:tag
APP_IMAGE=your-dockerhub-username/12th-be:latest

# Host binding (Nginx reverse proxy -> 127.0.0.1:8080)
BIND_ADDRESS=127.0.0.1
APP_PORT=8080
TZ=Asia/Seoul
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0 -Dfile.encoding=UTF-8

# MySQL (AWS RDS)
DB_URL=jdbc:mysql://your-rds-endpoint:3306/be12th
DB_USERNAME=be12th
DB_PASSWORD=change-me

# Redis (AWS ElastiCache or another private Redis instance)
REDIS_HOST=your-redis-endpoint
REDIS_PORT=6379

# Google OAuth / Gmail SMTP
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
REDIRECT_URI=https://api.example.com/login/oauth2/code/google
GOOGLE_EMAIL=change-me@example.com
GOOGLE_PASSWORD=change-me

# Application secrets and external APIs
JWT_SECRET_KEY=replace-with-a-long-random-secret-key
API_FOOTBALL_KEY=change-me
SOLAPI_API_KEY=change-me
SOLAPI_API_SECRET=change-me
SOLAPI_SENDER=01000000000

# Scheduled synchronization
PLAYER_SYNC_ENABLED=true
PLAYER_SYNC_CRON=0 0 1 * * *
TEAM_SYNC_ENABLED=true
TEAM_SYNC_CRON=0 30 0 * * *
MATCH_SYNC_ENABLED=true
MATCH_SYNC_CRON=0 0 0 * * *

# Firebase is disabled by default. To enable it, mount the key in compose.yaml.
FIREBASE_ENABLED=false
FIREBASE_CONFIG_PATH=/run/secrets/firebase-service-key.json
